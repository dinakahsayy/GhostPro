# Copy to .env and fill in real values. Never commit the populated .env.

# Flask
FLASK_APP=main.py
FLASK_ENV=development
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=replace-me-with-32-byte-random-value

# Optional dedicated key for encrypting LinkedIn tokens at rest (Fernet).
# If unset, a key is derived from SECRET_KEY. Generate a real one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: changing this (or SECRET_KEY when this is unset) invalidates all
# previously stored LinkedIn tokens — affected users must re-connect.
FERNET_KEY=

# Database (defaults to local SQLite if unset)
DATABASE_URL=sqlite:///ghostpro.db

# OpenAI
OPENAI_API_KEY=sk-...

# LinkedIn OAuth 2.0
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8080/linkedin/callback
